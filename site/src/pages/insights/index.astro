---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('insights'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const title = 'Insights — Gad Sosa';
const description =
  'Writing on machine-learning security, scaling engineering teams, and the technology decisions that make or break a company.';
---

<Layout title={title} description={description} canonical="/insights">
  <section class="article-layout">
    <div class="wrap">
      <div class="sec-head">
        <h2 class="sec-title">Insights</h2>
      </div>
      <p class="sec-sub">{description}</p>

      <div class="posts">
        {
          posts.map((post) => (
            <a href={`/insights/${post.id}/`} class="post">
              <span class="post-date">
                {post.data.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </span>
              <div class="txt">
                <span class="post-tag">{post.data.tag}</span>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
              </div>
              <span class="post-arrow" aria-hidden="true">
                →
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
