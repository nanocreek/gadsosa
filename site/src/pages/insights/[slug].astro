---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('insights');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const title = `${post.data.title} — Gad Sosa`;
const description = post.data.description;
const canonical = `/insights/${post.id}/`;
const publishedTime = post.data.date.toISOString();
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  type="article"
  publishedTime={publishedTime}
>
  <Fragment slot="head-append">
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: post.data.title,
      description: post.data.description,
      url: `${Astro.site?.toString().replace(/\/$/, '')}${canonical}`,
      datePublished: publishedTime,
      author: {
        '@type': 'Person',
        name: 'Gad Sosa',
        url: Astro.site?.toString().replace(/\/$/, ''),
      },
      publisher: {
        '@type': 'Person',
        name: 'Gad Sosa',
      },
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': `${Astro.site?.toString().replace(/\/$/, '')}${canonical}`,
      },
    })} />
  </Fragment>

  <article class="article-layout">
    <div class="wrap">
      <header class="article-header">
        <span class="article-tag">{post.data.tag}</span>
        <h1 class="sec-title" style="max-width: none;">{post.data.title}</h1>
        <time class="article-date" datetime={publishedTime}>
          {post.data.date.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
      </header>

      <div class="article-content">
        <Content />
      </div>
    </div>
  </article>
</Layout>
