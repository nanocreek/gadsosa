---
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'insights'>[];
}

const { posts } = Astro.props;

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<section id="insights" class="section-pad">
  <div class="wrap">
    <div class="sec-head">
      <span class="sec-num">§04 / 07</span>
      <h2 class="sec-title">Insights</h2>
    </div>
    <p class="sec-sub">
      Writing on machine-learning security, scaling engineering teams, and the technology decisions that make or break a company.
    </p>

    <div class="posts">
      {posts.map((post) => (
        <a href={`/insights/${post.id}/`} class="post">
          <span class="post-date">{formatDate(post.data.date)}</span>
          <div class="txt">
            <span class="post-tag">{post.data.tag}</span>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
          </div>
          <span class="post-arrow" aria-hidden="true">→</span>
        </a>
      ))}
    </div>
  </div>
</section>
